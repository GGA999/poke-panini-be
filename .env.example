NODE_ENV=development
DATABASE_PROVIDER=supabase
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/poke_panini
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-key
LOG_LEVEL=info
REQUEST_BODY_LIMIT=64kb
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=120
PRICING_RATE_LIMIT_WINDOW_MS=60000
PRICING_RATE_LIMIT_MAX=30
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX=10
